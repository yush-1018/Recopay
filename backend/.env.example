# ─────────────────────────────────────────────────────────────────────────────
# RecoPay — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── DATABASE ─────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string.
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>
# Get it from: https://cloud.mongodb.com → Clusters → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/recopay

# ── AUTHENTICATION ────────────────────────────────────────────────────────────
# A long, random secret string used to sign and verify JWT tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_min_32_chars

# ── RAZORPAY PAYMENT GATEWAY ─────────────────────────────────────────────────
# Obtain from: https://dashboard.razorpay.com → Settings → API Keys
# Use test keys (rzp_test_*) for development, live keys for production.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_SECRET=your_razorpay_key_secret

# Webhook secret set in: https://dashboard.razorpay.com → Webhooks
# Used to verify the authenticity of incoming Razorpay webhook events.
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ── SERVER ───────────────────────────────────────────────────────────────────
# Port the Express server listens on. Defaults to 5000 if not set.
# On Render this is set automatically — do not override it there.
PORT=5000
