# ─────────────────────────────────────────────────────────────────────────────
# RecoPay — Frontend Environment Variables (Vite)
# Copy this file to .env and fill in your values.
# All variables MUST be prefixed with VITE_ to be accessible in the browser.
# NEVER commit the actual .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── API ───────────────────────────────────────────────────────────────────────
# Base URL of the backend API (no trailing slash).
# Development:  http://localhost:5000/api
# Production:   https://recopay.onrender.com/api
VITE_API_URL=http://localhost:5000/api

# ── GOOGLE OAUTH ──────────────────────────────────────────────────────────────
# Google OAuth 2.0 Client ID.
# Get it from: https://console.cloud.google.com → APIs & Services → Credentials
# Make sure to add your domain to "Authorised JavaScript origins":
#   - http://localhost:5173  (local dev)
#   - https://your-app.vercel.app  (production)
VITE_GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
